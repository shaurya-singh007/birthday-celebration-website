{
  "functions": {
    "*.php": {
      "runtime": "vercel-php@0.7.1"
    }
  },
  "routes": [
    {
      "src": "/css/(.*)",
      "dest": "/css/$1"
    },
    {
      "src": "/js/(.*)",
      "dest": "/js/$1"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/logout.php",
      "dest": "/logout.php"
    },
    {
      "src": "/authenticate.php",
      "dest": "/authenticate.php"
    },
    {
      "src": "/home.php",
      "dest": "/home.php"
    },
    {
      "src": "/(.*)",
      "dest": "/index.php"
    }
  ]
}
